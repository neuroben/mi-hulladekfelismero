# Python bytecode / cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Distribution / packaging
dist/
build/
*.egg-info/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Model checkpoints (keep the directory, ignore weight files)
models/*.pth
models/*.pt

# Dataset images (keep folder structure via .gitkeep)
dataset/train/*/*
!dataset/train/*/.gitkeep
dataset/val/*/*
!dataset/val/*/.gitkeep
dataset/test/*/*
!dataset/test/*/.gitkeep

# OS artefacts
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/

# Logs
*.log
runs/
